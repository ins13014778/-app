                .width(32)
                .height(32)
                .fillColor('#E34607')

              Text(this.temperature > 0 ? `${this.temperature}°C` : '--')
                .fontSize(22)
                .fontWeight(FontWeight.Bold)
                .fontColor(this.temperature > 0 ? '#E34607' : '#CCCCCC')
                .margin({ top: 6 })

              Text('环境温度')
                .fontSize(12)
                .fontColor('#8A8F99')
                .margin({ top: 4 })
