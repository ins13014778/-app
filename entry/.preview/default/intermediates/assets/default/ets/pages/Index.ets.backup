            .layoutWeight(1)
            .alignItems(HorizontalAlign.Center)
            .padding(16)
            .backgroundColor('#FFFFFF')
            .borderRadius(12)
            .margin({ left: 8, right: 8 })

            // 光照强度
            Column() {
              Image($rawfile('光照强度-copy.png'))
