          .fontWeight(FontWeight.Bold)
          .fontColor('#1F2329')
          .layoutWeight(1)

        // AI聊天按钮
        Button({ type: ButtonType.Normal }) {
          Row() {
            Image($rawfile('deepseek-copy-copy-copy.png'))
              .width(16)
              .height(16)
              .fillColor('#666666')
              .margin({ right: 4 })
            Text('AI')
              .fontSize(13)
              .fontColor('#666666')
          }
        }
        .backgroundColor('#F5F5F5')
        .borderRadius(16)
        .height(32)
        .padding({ left: 12, right: 12 })
