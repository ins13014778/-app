          right: 16,
          top: 8,
          bottom: 8
        })
      }
      .layoutWeight(1)
      .backgroundColor('#F5F5F5')
      .scrollBar(BarState.Off)

      // 快速问题按钮
      if (this.aiMessages.length <= 1 && !this.isAILoading) {
