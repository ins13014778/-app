import { apiService, LoginRequest, RegisterRequest, SensorDataUploadRequest } from '../services/ApiService';
import { mqttService, MqttStatus, MqttMessage } from '../services/MqttService';
import { bemfaCloudService, TopicDetail, MessageRecord } from '../services/BemfaCloudService';
import cozeService from '../services/CozeService';
import { BemfaConfig } from '../config/BemfaConfig';
import { router } from '@kit.ArkUI';
import { common } from '@kit.AbilityKit';
import { preferences } from '@kit.ArkData';

// 控制设备接口定义（替代原灌溉设备）
interface ControlDevice {
  id: number;
  name: string;
  topic: string; // MQTT主题
  isActive: boolean;
  isOnline: boolean; // 在线状态
  area: string;
  deviceType: string; // 设备类型
}

// 分析数据接口定义
interface AnalysisData {
  date: string;
  temperature: number;
  humidity: number;
  soilMoisture: number;
  yield: number;
}

// AI消息接口
interface AIMessage {
  role: 'user' | 'assistant';
  content: string;
  timestamp: number;
}

// 用户信息接口定义
interface UserProfile {
  id: number;
  avatar: string;
  username: string;
  phone: string;
  email: string;
  bio: string;
  user_mode: string;
  is_admin?: number; // ✅ 添加管理员标识
}

// 菜单项接口定义
interface ProfileMenuItem {
  id: string;
  title: string;
  icon: string;
  hasArrow: boolean;
}

@Entry
@Component
struct Index {
  // 农场数据状态（初始值为0，等待传感器实时数据）
  @State soilHumidity: number = 0;
  @State temperature: number = 0;
  @State lightIntensity: number = 0;
  // 日期显示
  @State date: string = '10月10日';
  // 系统状态（已改为动态计算，无需状态变量）

  // 当前选中的标签页
  @State currentIndex: number = 0;
  // 登录注册状态管理
  @State isLoggedIn: boolean = false;
  @State userMode: string = 'not_logged_in'; // 'not_logged_in', 'guest', 'logged_in'
  @State currentView: string = 'login'; // 'login', 'register', 'main'
  @State username: string = '';
  @State password: string = '';
  @State confirmPassword: string = '';
  @State email: string = '';
  @State phone: string = '';
  @State isLoading: boolean = false;
  @State errorMessage: string = '';
  @State successMessage: string = '';
  // 用户信息状态
  @State userProfile: UserProfile = {
    id: 0,
    username: '',
    email: '',
    phone: '',
    avatar: '👤',
    bio: '智慧农业用户',
    user_mode: 'not_logged_in',
    is_admin: 0  // ✅ 默认为普通用户
  };
  // 控制设备状态管理（动态加载，不再硬编码）
  @State controlDevices: ControlDevice[] = [];
  @State activeDeviceCount: number = 0;
  @State onlineDeviceCount: number = 0;
  // MQTT连接状态
  @State mqttStatus: MqttStatus = MqttStatus.DISCONNECTED;
  @State mqttStatusText: string = '未连接';
  @State bemfaUID: string = ''; // 巴法云UID
  // 修改昵称对话框状态
  @State showEditNameDialog: boolean = false;
  @State editingDevice: ControlDevice | null = null;
  @State newDeviceName: string = '';
  // 🔥 AI聊天相关状态变量
  @State aiMessages: AIMessage[] = [];
  @State aiInputText: string = '';
  @State isAILoading: boolean = false;
  @State aiQuickQuestions: string[] = [];
  private aiChatScroller: Scroller = new Scroller();
  // 分析数据状态管理（简化版 - 用于演示）
  @State analysisData: AnalysisData[] = [];
  @State selectedDataType: string = '温度';
  @State lastUpdateTime: string = '--:--'; // 最后更新时间
  // 今日数据统计
  @State todayMaxTemp: number = 0; // 今日最高温度
  @State todayMinTemp: number = 0; // 今日最低温度
  @State todayMaxHumidity: number = 0; // 今日最高湿度
  @State todayMinHumidity: number = 0; // 今日最低湿度
  // 历史消息相关状态
  @State selectedDeviceForHistory: string = ''; // 选中查看历史的设备主题
  @State historyMessages: MessageRecord[] = []; // 历史消息列表
  @State isLoadingHistory: boolean = false; // 是否正在加载历史消息
  // 定时器ID
  private dateTimerID: number = -1;
  private dataRefreshTimerID: number = -1;
  private sensorDataRefreshTimerID: number = -1;

  // 页面生命周期 - 页面即将显示
  aboutToAppear() {
    console.info('[Index] 页面即将显示');
    // 设置API服务的context
    apiService.setContext(this.getUIContext().getHostContext() as common.UIAbilityContext);
    // 从本地存储加载巴法云UID
    this.loadBemfaUID();

    // 启动定时器更新日期
    this.updateDateTime();
    this.dateTimerID = setInterval(() => {
      this.updateDateTime();
    }, 60000); // 每分钟更新一次

    // 启动定时器刷新设备在线状态（每30秒）
    this.dataRefreshTimerID = setInterval(() => {
      if (this.controlDevices.length > 0) {
        this.refreshDeviceOnlineStatus();
      }
    }, 30000);

    // 启动定时器刷新传感器数据（每10秒）
    this.sensorDataRefreshTimerID = setInterval(() => {
      if (this.controlDevices.length > 0) {
        this.refreshSensorData();
      }
    }, 10000);

    // 🔥 初始化AI服务
    this.initAIService();
  }

  // 页面生命周期 - 页面即将销毁
  aboutToDisappear() {
    console.info('[Index] 页面即将销毁');
    // 清除定时器
    if (this.dateTimerID !== -1) {
      clearInterval(this.dateTimerID);
    }
    if (this.dataRefreshTimerID !== -1) {
      clearInterval(this.dataRefreshTimerID);
    }
    if (this.sensorDataRefreshTimerID !== -1) {
      clearInterval(this.sensorDataRefreshTimerID);
    }
    // 断开MQTT连接
    mqttService.disconnect();
  }

  // 更新日期时间
  updateDateTime() {
    const now = new Date();
    const month = now.getMonth() + 1;
    const day = now.getDate();
    this.date = `${month}月${day}日`;
    console.info('[Index] 日期更新:', this.date);
  }

  // 从本地存储加载UID
  async loadBemfaUID() {
    try {
      // 优先使用配置文件中的默认UID
      if (BemfaConfig.USER_UID && BemfaConfig.USER_UID.length > 0) {
        this.bemfaUID = BemfaConfig.USER_UID;
        bemfaCloudService.setUID(this.bemfaUID);
        console.info('[Index] 使用内置UID:', this.bemfaUID.substring(0, 8) + '...');

        // 自动同步设备列表
        await this.syncDevicesFromBemfa();

        // 然后连接MQTT
        await this.initMQTT();
        return;
      }
      // 如果配置文件没有，则从本地存储读取
      let pref =
        await preferences.getPreferences(this.getUIContext().getHostContext() as common.UIAbilityContext, 'app_config');
      let savedUID: string = await pref.get(BemfaConfig.STORAGE_KEY_UID, '') as string;

      if (savedUID && typeof savedUID === 'string') {
        this.bemfaUID = savedUID as string;
        bemfaCloudService.setUID(this.bemfaUID);
        console.info('[Index] 已加载保存的UID');

        // 自动同步设备列表
        await this.syncDevicesFromBemfa();

        // 然后连接MQTT
        await this.initMQTT();
      } else {
        console.warn('[Index] UID未配置，请在控制页面配置');
      }
    } catch (error) {
      console.error('[Index] 加载UID失败:', error);
    }
  }

  // 保存UID到本地存储和云端
  async saveBemfaUID(uid: string): Promise<void> {
    try {
      // 1. 保存到本地
      let pref =
        await preferences.getPreferences(this.getUIContext().getHostContext() as common.UIAbilityContext, 'app_config');
      await pref.put(BemfaConfig.STORAGE_KEY_UID, uid);
      await pref.flush();

      this.bemfaUID = uid;
      bemfaCloudService.setUID(uid);
      console.info('[Index] UID已保存到本地');

      // 2. 如果用户已登录，保存到云端
      if (this.isLoggedIn && apiService.hasToken()) {
        try {
          const result = await apiService.saveUserConfig({ bemfa_uid: uid });
          if (result.success) {
            console.info('[Index] UID已同步到云端');
          } else {
            console.warn('[Index] UID云端同步失败（不影响使用）:', result.message);
          }
        } catch (error) {
          console.warn('[Index] UID云端同步异常（不影响使用）:', error);
        }
      }

      // 3. 保存成功后自动同步设备并连接MQTT
      await this.syncDevicesFromBemfa();
      await this.initMQTT();
    } catch (error) {
      console.error('[Index] 保存UID失败:', error);
    }
  }

  build() {
    Stack() {
      if (this.userMode === 'not_logged_in') {
        // 未登录状态，显示登录或注册界面
        if (this.currentView === 'login') {
          this.LoginPageContent()
        } else if (this.currentView === 'register') {
          this.RegisterPageContent()
        }
      } else {
        // 已登录或游客模式，显示主应用界面
        // 使用Tabs作为主容器，底部导航栏
        Tabs({ barPosition: BarPosition.End, index: this.currentIndex }) {
          // 首页标签页
          TabContent() {
            this.HomePageContent()
          }.tabBar(this.TabBuilder('首页', 0))

          // 控制页面标签页
          TabContent() {
            this.ControlPageContent()
          }.tabBar(this.TabBuilder('控制', 1))

          // 分析页面标签页
          TabContent() {
            this.AnalysisPageContent()
          }.tabBar(this.TabBuilder('分析', 2))

          // 用户页面标签页
          TabContent() {
            this.ProfilePageContent()
          }.tabBar(this.TabBuilder('我的', 3))
        }
        .onChange((index: number) => {
          this.currentIndex = index;
        })
        .width('100%')
        .height('100%')
        .padding(0)
        .margin(0)
        .backgroundColor('#F5F5F5')
      }

      // 编辑设备昵称对话框
      if (this.showEditNameDialog) {
        this.EditDeviceNameDialog()
      }
    }
    .width('100%')
    .height('100%')
    .padding(0)
    .margin(0)
    .alignContent(Alignment.TopStart)
  }

  // 编辑设备昵称对话框
  @Builder
  EditDeviceNameDialog() {
    Column() {
      // 遮罩层
      Column()
        .width('100%')
        .height('100%')
        .backgroundColor('#80000000')
        .onClick(() => {
          this.showEditNameDialog = false;
        })

      // 对话框内容
      Column() {
        // 标题
        Text('修改设备昵称')
          .fontSize(18)
          .fontWeight(FontWeight.Bold)
          .margin({ bottom: 20 })

        // 设备信息
        if (this.editingDevice) {
          Column() {
            Row() {
              Text('主题:')
                .fontSize(14)
                .fontColor('#666666')
                .width(60)
              Text(this.editingDevice.topic)
                .fontSize(14)
                .fontColor('#333333')
            }
            .width('100%')
            .margin({ bottom: 8 })

            Row() {
              Text('类型:')
                .fontSize(14)
                .fontColor('#666666')
                .width(60)
              Text(this.editingDevice.deviceType)
                .fontSize(14)
                .fontColor('#333333')
            }
            .width('100%')
            .margin({ bottom: 16 })
          }
          .alignItems(HorizontalAlign.Start)
        }

        // 输入框
        Column() {
          Text('新昵称')
            .fontSize(14)
            .fontColor('#666666')
            .alignSelf(ItemAlign.Start)
            .margin({ bottom: 8 })

          TextInput({ text: this.newDeviceName })
            .width('100%')
            .height(44)
            .fontSize(16)
            .borderRadius(8)
            .backgroundColor('#F5F5F5')
            .onChange((value: string) => {
              this.newDeviceName = value;
            })
        }
        .margin({ bottom: 24 })

        // 按钮组
        Row() {
          Button('取消')
            .fontSize(16)
            .fontColor('#666666')
            .backgroundColor('#F5F5F5')
            .borderRadius(8)
            .layoutWeight(1)
            .height(44)
            .onClick(() => {
              this.showEditNameDialog = false;
            })

          Button('确定')
            .fontSize(16)
            .fontColor('#FFFFFF')
            .backgroundColor('#007DFF')
            .borderRadius(8)
            .layoutWeight(1)
            .height(44)
            .margin({ left: 12 })
            .onClick(() => {
              this.confirmEditDeviceName();
            })
        }
        .width('100%')
      }
      .width('85%')
      .padding(24)
      .backgroundColor('#FFFFFF')
      .borderRadius(16)
      .position({ x: '7.5%', y: '30%' })
    }
    .width('100%')
    .height('100%')
    .position({ x: 0, y: 0 })
    .zIndex(1000)
  }

  // 首页内容组件
