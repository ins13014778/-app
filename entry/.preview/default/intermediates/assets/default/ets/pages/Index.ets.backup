  // ==============================================
  // 分析页面数据处理方法（简单易懂）
  // ==============================================

  // 更新分析数据
  updateAnalysisData() {
    console.info('[分析] 更新数据');

    // 获取当前时间
    const now = new Date();
    const timeStr = `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;
    this.lastUpdateTime = timeStr;

    // 记录当前数据到历史
    const newData: AnalysisData = {
      date: timeStr,
      temperature: this.temperature,
      humidity: this.soilHumidity,
      soilMoisture: this.lightIntensity, // 用光照强度代替土壤湿度
      yield: 0  // 产量暂不使用
    };

    // 添加到数组开头，保持最新的在前面
    this.analysisData.unshift(newData);

    // 只保留最近10条记录（演示用）
    if (this.analysisData.length > 10) {
      this.analysisData.pop(); // 删除最旧的
    }

    // 更新今日最高最低值
    this.updateTodayStats();

    console.info('[分析] 记录数据:', `温度${this.temperature}°C 湿度${this.soilHumidity}%`);
  }

  // 更新今日统计（计算最高最低值）
  updateTodayStats() {
    if (this.analysisData.length === 0) {
      return;
    }

    // 计算温度的最高最低值
    const temps = this.analysisData.map(d => d.temperature);
    this.todayMaxTemp = Math.max(...temps);
    this.todayMinTemp = Math.min(...temps);

    // 计算湿度的最高最低值
    const humidities = this.analysisData.map(d => d.humidity);
    this.todayMaxHumidity = Math.max(...humidities);
    this.todayMinHumidity = Math.min(...humidities);

    console.info('[分析] 今日统计:',
      `温度 ${this.todayMinTemp}-${this.todayMaxTemp}°C, 湿度 ${this.todayMinHumidity}-${this.todayMaxHumidity}%`);
  }

