            Image($rawfile('B站狗头.png'))
              .width(80)
              .height(80)
              .borderRadius(40)
              .margin({ bottom: 12 })

            Text('游客用户')
              .fontSize(20)
              .fontWeight(FontWeight.Bold)
              .fontColor('#333333')
              .margin({ bottom: 4 })

            Text('登录后享受更多个性化服务')
              .fontSize(14)
              .fontColor('#666666')
              .margin({ bottom: 16 })

            // 登录按钮
            Button('立即登录')
              .width(120)
              .height(36)
              .backgroundColor('#007AFF')
              .borderRadius(18)
              .fontSize(14)
              .fontColor('#FFFFFF')
              .onClick(() => {
                this.userMode = 'not_logged_in';
                this.currentView = 'login';
              })
          }
          .alignItems(HorizontalAlign.Center)
          .padding({ top: 32, bottom: 24 })
        } else {
          // 已登录用户显示
          Column() {
            Image($rawfile('B站狗头.png'))
              .width(80)
              .height(80)
              .borderRadius(40)
              .margin({ bottom: 12 })

            // 用户名和管理员标识
            Row() {
              Text(this.userProfile.username)
                .fontSize(20)
                .fontWeight(FontWeight.Bold)
                .fontColor('#333333')

              // ✅ 管理员标识徽章
              if (this.userProfile.is_admin === 1) {
                Text('👑 管理员')
                  .fontSize(14)
                  .fontColor('#FFFFFF')
                  .backgroundColor('#FF6B35')
                  .padding({
                    left: 8,
                    right: 8,
                    top: 4,
                    bottom: 4
                  })
                  .borderRadius(12)
                  .margin({ left: 8 })
              }
            }
            .margin({ bottom: 4 })

            Text(this.userProfile.bio)
              .fontSize(14)
              .fontColor('#666666')
              .margin({ bottom: 8 })

            Text(this.userProfile.phone)
              .fontSize(14)
              .fontColor('#999999')
          }
          .alignItems(HorizontalAlign.Center)
          .padding({ top: 32, bottom: 24 })
        }
      }
      .width('100%')
      .backgroundColor('#FFFFFF')
      .borderRadius(12)
      .margin({ top: 16, bottom: 16 })

      // 快捷操作按钮（仅登录用户可见）
      if (this.userMode === 'logged_in') {
        Row() {
          // 编辑资料按钮
          Button() {
            Column() {
              Image($rawfile('编辑资料.png'))
                .width(24)
                .height(24)
                .fillColor('#007AFF')
                .margin({ bottom: 4 })
              Text('编辑资料')
                .fontSize(14)
                .fontColor('#333333')
            }
          }
          .layoutWeight(1)
          .height(80)
          .backgroundColor('#FFFFFF')
          .borderRadius(12)
          .onClick(() => {
            console.info('[Profile] 跳转到编辑资料页面');
            router.pushUrl({
              url: 'pages/EditProfile',
              params: {
                username: this.userProfile.username,
                email: this.userProfile.email,
                phone: this.userProfile.phone || '',
                bio: this.userProfile.bio,
                avatar: this.userProfile.avatar
              }
            }).catch((err: Error) => {
              console.error('[Profile] 跳转编辑资料失败:', JSON.stringify(err));
            });
          })

          // 间距
          Blank().width(12)

          // 修改密码按钮
          Button() {
            Column() {
              Image($rawfile('修改密码.png'))
                .width(24)
                .height(24)
                .fillColor('#007AFF')
                .margin({ bottom: 4 })
              Text('修改密码')
                .fontSize(14)
                .fontColor('#333333')
            }
          }
          .layoutWeight(1)
          .height(80)
          .backgroundColor('#FFFFFF')
          .borderRadius(12)
          .onClick(() => {
            console.info('[Profile] 跳转到修改密码页面');
            router.pushUrl({
              url: 'pages/ChangePassword'
            }).catch((err: Error) => {
              console.error('[Profile] 跳转修改密码失败:', JSON.stringify(err));
            });
          })
        }
        .width('100%')
        .margin({ bottom: 16 })
      }

      // 功能菜单列表
      Column() {
        List() {
          ForEach(this.getMenuItemsForCurrentMode(), (item: ProfileMenuItem, index: number) => {
            ListItem() {
              this.MenuItemCard(item)
            }
            .margin({ bottom: index < this.getMenuItemsForCurrentMode().length - 1 ? 1 : 0 })
          })
        }
        .width('100%')
        .height('auto')
        .divider({ strokeWidth: 1, color: '#F0F0F0' })
      }
      .width('100%')
      .backgroundColor('#FFFFFF')
      .borderRadius(12)
      .margin({ bottom: 16 })
    }
    .width('100%')
    .height('100%')
    .padding(16)
    .backgroundColor('#F5F5F5')
  }

  // 菜单项卡片
  @Builder
  MenuItemCard(item: ProfileMenuItem) {
    Row() {
      // 判断是否为图片路径
      if (item.icon.endsWith('.png')) {
        Image($rawfile(item.icon))
          .width(20)
          .height(20)
          .fillColor('#666666')
          .margin({ right: 12 })
      } else {
        Text(item.icon)
          .fontSize(20)
          .margin({ right: 12 })
      }

      Text(item.title)
        .fontSize(16)
        .fontColor('#333333')
        .layoutWeight(1)

      if (item.hasArrow) {
        Image($rawfile('右箭头.png'))
          .width(16)
          .height(16)
          .fillColor('#CCCCCC')
      }
    }
    .width('100%')
    .padding({
      left: 16,
      right: 16,
      top: 16,
      bottom: 16
    })
    .backgroundColor('#FFFFFF')
    .onClick(() => {
      this.handleMenuItemClick(item.id);
    })
  }

  // 处理菜单项点击事件
  handleMenuItemClick(itemId: string) {
    // 游客模式下某些功能需要登录
    if (this.userMode === 'guest' && (itemId === 'profile' || itemId === 'settings')) {
      // 提示需要登录
      console.log('游客模式，需要登录才能访问此功能');
      this.userMode = 'not_logged_in';
      this.currentView = 'login';
      return;
    }

    switch (itemId) {
      case 'profile':
        // 跳转到个人资料页面
        console.log('跳转到个人资料页面');
        break;
      case 'settings':
        // 跳转到系统设置页面
        console.log('跳转到系统设置页面');
        break;
      case 'help':
        // 跳转到帮助与反馈页面
        console.log('跳转到帮助与反馈页面');
        break;
      case 'about':
        // 跳转到关于我们页面
        console.log('跳转到关于我们页面');
        break;
      case 'logout':
        // 执行退出登录操作
        console.log('执行退出登录操作');
        this.handleLogout();
        break;
      default:
        console.log('未知菜单项:', itemId);
    }
  }

  // 登录表单验证
  private validateLoginForm(): boolean {
    if (!this.username.trim()) {
      this.errorMessage = '请输入用户名';
      return false;
    }
    if (!this.password.trim()) {
      this.errorMessage = '请输入密码';
      return false;
    }
    if (this.password.length < 6) {
      this.errorMessage = '密码长度不能少于6位';
      return false;
    }
    this.errorMessage = '';
    return true;
  }

  // 注册表单验证
  private validateRegisterForm(): boolean {
    if (!this.username.trim()) {
      this.errorMessage = '请输入用户名';
      return false;
    }
    if (!this.phone.trim()) {
      this.errorMessage = '请输入手机号';
      return false;
    }
    if (!this.email.trim()) {
      this.errorMessage = '请输入邮箱';
      return false;
    }
    if (!this.password.trim()) {
      this.errorMessage = '请输入密码';
      return false;
    }
    if (this.password.length < 6) {
      this.errorMessage = '密码长度不能少于6位';
      return false;
    }
    if (this.password !== this.confirmPassword) {
      this.errorMessage = '两次输入的密码不一致';
      return false;
    }
    this.errorMessage = '';
    return true;
  }

  // 处理登录
  private async handleLogin(): Promise<void> {
    if (!this.validateLoginForm()) {
      return;
    }

    this.isLoading = true;
    this.errorMessage = '';
    this.successMessage = '';

    try {
      const loginData: LoginRequest = {
        login: this.username.trim(),
        password: this.password
      };

      console.log('开始登录请求:', loginData.login);
      const response = await apiService.login(loginData);

      if (response.success && response.data) {
        // 登录成功
        this.userProfile = {
          id: response.data.user.id,
          username: response.data.user.username,
          email: response.data.user.email,
          phone: response.data.user.phone || '',
          avatar: response.data.user.avatar || '👤',
          bio: response.data.user.bio || '智慧农业用户',
          user_mode: response.data.user.user_mode,
          is_admin: response.data.user.is_admin || 0  // ✅ 保存管理员标识
        };

        this.isLoggedIn = true;
        this.userMode = 'logged_in';
        this.currentView = 'main';
        this.successMessage = '登录成功！';
        this.clearForm();

        console.log('登录成功:', this.userProfile.username);
      } else {
        // 登录失败
        this.errorMessage = response.message || '登录失败，请检查用户名和密码';
        console.error('登录失败:', response.message);
      }
    } catch (error) {
      console.error('登录异常:', error);
      this.errorMessage = '网络连接失败，请检查网络设置';
    } finally {
      this.isLoading = false;
    }
  }

  // 处理注册
  private async handleRegister(): Promise<void> {
    if (!this.validateRegisterForm()) {
      return;
    }

    this.isLoading = true;
    this.errorMessage = '';
    this.successMessage = '';

    try {
      const registerData: RegisterRequest = {
        username: this.username.trim(),
        email: this.email.trim(),
        phone: this.phone.trim(),
        password: this.password
      };

      console.log('开始注册请求:', registerData.username);
      const response = await apiService.register(registerData);

      if (response.success && response.data) {
        // 注册成功，保存token
        if (response.data.token) {
          apiService.setToken(response.data.token);
          console.log('✅ Token已保存');
        }

        // 更新用户信息
        this.userProfile = {
          id: response.data.user.id,
          username: response.data.user.username,
          email: response.data.user.email,
          phone: response.data.user.phone || '',
          avatar: response.data.user.avatar || '👤',
          bio: response.data.user.bio || '智慧农业用户',
          user_mode: response.data.user.user_mode,
          is_admin: response.data.user.is_admin || 0  // ✅ 保存管理员标识
        };

        console.log('✅ 注册成功:', this.userProfile.username);
        this.successMessage = '注册成功！';

        // 延迟1秒后跳转（给UI时间渲染）
        setTimeout(() => {
          this.isLoggedIn = true;
          this.userMode = 'logged_in';
          this.currentView = 'main';
          this.clearForm();
          this.successMessage = ''; // 清除成功消息
          console.log('✅ 已跳转到主界面');
        }, 1000);

      } else {
        // 注册失败
        this.errorMessage = response.message || '注册失败，请检查输入信息';
        console.error('注册失败:', response.message);
      }
    } catch (error) {
      console.error('注册异常:', error);
      this.errorMessage = '网络连接失败，请检查网络设置';
    } finally {
      this.isLoading = false;
    }
  }

  // 处理退出登录
  private async handleLogout(): Promise<void> {
    this.isLoading = true;

    try {
      console.log('开始登出请求');
      const response = await apiService.logout();

      if (response.success) {
        console.log('登出成功');
      } else {
        console.warn('登出请求失败，但继续清除本地状态');
      }
    } catch (error) {
      console.error('登出异常:', error);
    } finally {
      // 无论服务器响应如何，都清除本地状态
      this.isLoggedIn = false;
      this.userMode = 'not_logged_in';
      this.currentView = 'login';
      this.userProfile = {
        id: 0,
        username: '',
        email: '',
        phone: '',
        avatar: '👤',
        bio: '智慧农业用户',
        user_mode: 'not_logged_in',
        is_admin: 0  // ✅ 重置管理员标识
      };
      this.clearForm();
      this.isLoading = false;
    }
  }

  // 处理游客模式进入
  private handleGuestMode(): void {
    console.log('以游客模式进入应用');
    this.isLoggedIn = false;
    this.userMode = 'guest';
    this.currentView = 'main';
    this.clearForm();
  }

  // 清空表单
  private clearForm(): void {
    this.username = '';
    this.password = '';
    this.confirmPassword = '';
    this.email = '';
    this.phone = '';
    this.errorMessage = '';
    this.successMessage = '';
  }

  // 切换到注册页面
  private switchToRegister(): void {
    this.currentView = 'register';
    this.clearForm();
  }

  // 切换到登录页面
  private switchToLogin(): void {
    this.currentView = 'login';
    this.clearForm();
  }

  // 登录页面内容组件
  @Builder
  LoginPageContent() {
    Column() {
      // 顶部标题区域
      Column() {
        // Logo图标
        Image($rawfile('登录.png'))
          .width(80)
          .height(80)
          .fillColor('#007AFF')
          .margin({ bottom: 16 })

        Text('欢迎回来')
          .fontSize(32)
          .fontWeight(FontWeight.Bold)
          .fontColor('#1a1a1a')
          .margin({ bottom: 8 })

        Text('登录智慧农业管理系统')
          .fontSize(16)
          .fontColor('#666666')
          .margin({ bottom: 48 })
      }
      .width('100%')
      .alignItems(HorizontalAlign.Center)
      .margin({ top: 80, bottom: 32 })

      // 登录表单区域
      Column() {
        // 用户名输入框
        Column() {
          Text('用户名')
            .fontSize(14)
            .fontColor('#666666')
            .fontWeight(FontWeight.Medium)
            .alignSelf(ItemAlign.Start)
            .margin({ bottom: 8, left: 4 })

          TextInput({ placeholder: '请输入用户名' })
            .width('100%')
            .height(52)
            .backgroundColor('#FFFFFF')
            .borderRadius(26)
            .padding({ left: 20, right: 20 })
            .fontSize(16)
            .placeholderColor('#BBBBBB')
            .border({ width: 1, color: '#E5E5E5' })
            .shadow({
              radius: 8,
              color: 'rgba(0, 0, 0, 0.04)',
              offsetX: 0,
              offsetY: 2
            })
            .onChange((value: string) => {
              this.username = value;
            })
        }
        .width('100%')
        .margin({ bottom: 20 })

        // 密码输入框
        Column() {
          Text('密码')
            .fontSize(14)
            .fontColor('#666666')
            .fontWeight(FontWeight.Medium)
            .alignSelf(ItemAlign.Start)
            .margin({ bottom: 8, left: 4 })

          TextInput({ placeholder: '请输入密码' })
            .width('100%')
            .height(52)
            .backgroundColor('#FFFFFF')
            .borderRadius(26)
            .padding({ left: 20, right: 20 })
            .fontSize(16)
            .placeholderColor('#BBBBBB')
            .type(InputType.Password)
            .border({ width: 1, color: '#E5E5E5' })
            .shadow({
              radius: 8,
              color: 'rgba(0, 0, 0, 0.04)',
              offsetX: 0,
              offsetY: 2
            })
            .onChange((value: string) => {
              this.password = value;
            })
        }
        .width('100%')
        .margin({ bottom: 32 })

        // 错误信息显示
        if (this.errorMessage) {
          Row() {
            Text('⚠️')
              .fontSize(16)
              .margin({ right: 6 })
            Text(this.errorMessage)
              .fontSize(14)
              .fontColor('#FF4444')
          }
          .width('100%')
          .padding(12)
          .backgroundColor('#FFF5F5')
          .borderRadius(12)
          .margin({ bottom: 20 })
        }

        // 成功信息显示
        if (this.successMessage) {
          Row() {
            Text('✓')
              .fontSize(16)
              .fontColor('#00AA00')
              .margin({ right: 6 })
            Text(this.successMessage)
              .fontSize(14)
              .fontColor('#00AA00')
          }
          .width('100%')
          .padding(12)
          .backgroundColor('#F0FFF4')
          .borderRadius(12)
          .margin({ bottom: 20 })
        }

        // 登录按钮 - 渐变椭圆
        Stack() {
          // 渐变背景
          if (!this.isLoading) {
            Column()
              .width('100%')
              .height(56)
              .borderRadius(28)
              .linearGradient({
                angle: 135,
                colors: [['#4facfe', 0.0], ['#00f2fe', 1.0]]
              })
              .shadow({
                radius: 16,
                color: 'rgba(79, 172, 254, 0.4)',
                offsetX: 0,
                offsetY: 8
              })
          } else {
            Column()
              .width('100%')
              .height(56)
              .borderRadius(28)
              .backgroundColor('#CCCCCC')
          }
          
          // 按钮内容
          Button({ type: ButtonType.Normal }) {
            Row() {
              if (!this.isLoading) {
                Image($rawfile('登录.png'))
                  .width(22)
                  .height(22)
                  .fillColor('#FFFFFF')
                  .margin({ right: 8 })
              }
              Text(this.isLoading ? '登录中...' : '立即登录')
                .fontSize(17)
                .fontColor('#FFFFFF')
                .fontWeight(FontWeight.Medium)
            }
            .justifyContent(FlexAlign.Center)
          }
          .width('100%')
          .height(56)
          .backgroundColor('transparent')
          .borderRadius(28)
          .enabled(!this.isLoading)
          .onClick(() => {
            this.handleLogin();
          })
        }
        .margin({ bottom: 16 })

        // 跳过登录按钮 - 椭圆边框
        Button('稍后登录，以游客身份使用')
          .width('100%')
          .height(52)
          .backgroundColor('transparent')
          .borderRadius(26)
          .fontSize(15)
          .fontColor('#4facfe')
          .fontWeight(FontWeight.Medium)
          .border({ width: 1.5, color: '#4facfe' })
          .onClick(() => {
            this.handleGuestMode();
          })
          .margin({ bottom: 24 })

        // 注册链接
        Row() {
          Text('还没有账号？')
            .fontSize(15)
            .fontColor('#999999')
            .margin({ right: 4 })

          Text('立即注册')
            .fontSize(15)
            .fontColor('#4facfe')
            .fontWeight(FontWeight.Medium)
            .onClick(() => {
              this.switchToRegister();
            })
        }
        .justifyContent(FlexAlign.Center)
        .padding(12)
      }
      .width('100%')
      .padding({ left: 32, right: 32 })
    }
    .width('100%')
    .height('100%')
    .linearGradient({
      angle: 180,
      colors: [['#FFFFFF', 0.0], ['#F8FCFF', 0.5], ['#EBF4FF', 1.0]]
    })
    .justifyContent(FlexAlign.Start)
  }

