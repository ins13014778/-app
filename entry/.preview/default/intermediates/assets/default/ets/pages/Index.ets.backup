              .alignSelf(ItemAlign.Start)
              .margin({ bottom: 8, left: 4 })

            TextInput({ placeholder: '请输入邮箱地址' })
              .width('100%')
              .height(50)
              .backgroundColor('#FFFFFF')
              .borderRadius(25)
              .padding({ left: 20, right: 20 })
              .fontSize(15)
              .placeholderColor('#BBBBBB')
              .type(InputType.Email)
              .border({ width: 1, color: '#E5E5E5' })
              .shadow({
                radius: 8,
                color: 'rgba(0, 0, 0, 0.04)',
                offsetX: 0,
                offsetY: 2
              })
              .onChange((value: string) => {
                this.email = value;
              })
          }
          .width('100%')
          .margin({ bottom: 16 })

        // 密码输入框
        Column() {
          Text('密码')
            .fontSize(14)
            .fontColor('#333333')
            .alignSelf(ItemAlign.Start)
            .margin({ bottom: 8 })

          TextInput({ placeholder: '请输入密码（至少6位）' })
            .width('100%')
            .height(48)
            .backgroundColor('#F8F8F8')
            .borderRadius(8)
            .padding({ left: 16, right: 16 })
            .fontSize(16)
            .type(InputType.Password)
            .onChange((value: string) => {
              this.password = value;
            })
        }
        .width('100%')
        .margin({ bottom: 16 })

        // 确认密码输入框
        Column() {
          Text('确认密码')
            .fontSize(14)
            .fontColor('#333333')
            .alignSelf(ItemAlign.Start)
            .margin({ bottom: 8 })

          TextInput({ placeholder: '请再次输入密码' })
            .width('100%')
            .height(48)
            .backgroundColor('#F8F8F8')
            .borderRadius(8)
            .padding({ left: 16, right: 16 })
            .fontSize(16)
            .type(InputType.Password)
            .onChange((value: string) => {
              this.confirmPassword = value;
            })
        }
        .width('100%')
        .margin({ bottom: 20 })

        // 错误信息显示
        if (this.errorMessage) {
          Text(this.errorMessage)
            .fontSize(14)
            .fontColor('#FF4444')
            .margin({ bottom: 20 })
        }

        // 成功信息显示
        if (this.successMessage) {
          Column() {
            Text(this.successMessage)
              .fontSize(14)
              .fontColor('#00AA00')
              .margin({ bottom: 12 })

            // 返回登录按钮
            Button('返回登录')
              .width('100%')
              .height(48)
              .backgroundColor('#00AA00')
              .borderRadius(8)
              .fontSize(16)
              .fontColor('#FFFFFF')
              .onClick(() => {
                this.switchToLogin();
              })
          }
          .width('100%')
          .margin({ bottom: 20 })
        }

          // 注册按钮 - 渐变椭圆
          if (!this.successMessage) {
            Stack() {
              // 渐变背景
              if (!this.isLoading) {
                Column()
                  .width('100%')
                  .height(54)
                  .borderRadius(27)
                  .linearGradient({
                    angle: 135,
                    colors: [['#a8e063', 0.0], ['#56ab2f', 1.0]]
                  })
                  .shadow({
                    radius: 16,
                    color: 'rgba(86, 171, 47, 0.4)',
                    offsetX: 0,
                    offsetY: 8
                  })
              } else {
                Column()
                  .width('100%')
                  .height(54)
                  .borderRadius(27)
                  .backgroundColor('#CCCCCC')
              }
              
              // 按钮内容
              Button({ type: ButtonType.Normal }) {
                Row() {
                  if (!this.isLoading) {
                    Image($rawfile('注册.png'))
                      .width(22)
                      .height(22)
                      .fillColor('#FFFFFF')
                      .margin({ right: 8 })
                  }
                  Text(this.isLoading ? '注册中...' : '立即注册')
                    .fontSize(17)
                    .fontColor('#FFFFFF')
                    .fontWeight(FontWeight.Medium)
                }
                .justifyContent(FlexAlign.Center)
              }
              .width('100%')
              .height(54)
              .backgroundColor('transparent')
              .borderRadius(27)
              .enabled(!this.isLoading)
              .onClick(() => {
                this.handleRegister();
              })
            }
            .margin({ bottom: 20 })
          }

          // 登录链接
          Row() {
            Text('已有账号？')
              .fontSize(15)
              .fontColor('#999999')
              .margin({ right: 4 })

            Text('立即登录')
              .fontSize(15)
              .fontColor('#56ab2f')
              .fontWeight(FontWeight.Medium)
              .onClick(() => {
                this.switchToLogin();
              })
          }
          .justifyContent(FlexAlign.Center)
          .padding(12)
        }
        .width('100%')
        .padding({ left: 32, right: 32 })
      }
      .layoutWeight(1)
    }
    .width('100%')
    .height('100%')
    .linearGradient({
      angle: 180,
      colors: [['#FFFFFF', 0.0], ['#F8FFF5', 0.5], ['#EBF5E8', 1.0]]
    })
    .justifyContent(FlexAlign.Start)
  }

  // ==============================================
  // 🔥 AI智能分析相关方法
  // ==============================================

  // 初始化AI服务
  initAIService() {
    console.info('[AI] 初始化AI服务');

    // 🔥 使用配置文件中的默认配置（无需传参）
    cozeService.init();

    // 获取快速问题
    this.aiQuickQuestions = cozeService.getQuickReplies();

    // 添加欢迎消息
    this.addWelcomeMessage();
  }

  // 添加欢迎消息
  addWelcomeMessage() {
    const welcomeMsg: AIMessage = {
      role: 'assistant',
      content: '你好！我是智慧农场AI助手🌾\n\n我可以：\n• 分析实时传感器数据\n• 提供种植建议\n• 回答农业问题\n• 给出优化方案\n\n请告诉我你想了解什么？',
      timestamp: Date.now()
    };
    this.aiMessages.push(welcomeMsg);
  }

  // 发送AI消息
  async sendAIMessage(userText: string) {
    console.info('[AI] 发送消息:', userText);

    // 构建完整消息（包含传感器数据上下文）
    let fullMessage = userText;

    // 如果有传感器数据，自动附加到消息中
    if (this.temperature > 0 || this.soilHumidity > 0 || this.lightIntensity > 0) {
      fullMessage += `\n\n【当前环境数据】`;
      if (this.temperature > 0) {
        fullMessage += `\n温度: ${this.temperature}°C`;
      }
      if (this.soilHumidity > 0) {
        fullMessage += `\n湿度: ${this.soilHumidity}%`;
      }
      if (this.lightIntensity > 0) {
        fullMessage += `\n光照: ${this.lightIntensity}Lx`;
      }
    }

    // 添加用户消息（显示原始消息，不显示传感器数据）
    const userMsg: AIMessage = {
      role: 'user',
      content: userText,
      timestamp: Date.now()
    };
    this.aiMessages.push(userMsg);

    // 滚动到底部
    setTimeout(() => {
      this.aiChatScroller.scrollEdge(Edge.Bottom);
    }, 100);

    // 显示加载状态
    this.isAILoading = true;

    // 创建AI消息占位符（用于流式更新）
    const assistantMsg: AIMessage = {
      role: 'assistant',
      content: '', // 初始为空，流式更新
      timestamp: Date.now()
    };
    this.aiMessages.push(assistantMsg);
    const aiMessageIndex = this.aiMessages.length - 1; // 记录索引

    // 调用Coze AI服务（流式输出）
    await cozeService.sendMessage(
      fullMessage,
      // onUpdate: 实时更新回调
      (deltaContent: string) => {
        console.info('[AI] 📝 收到增量:', deltaContent);
        
        // 🔥 修复：更新内容并触发UI刷新
        this.aiMessages[aiMessageIndex].content += deltaContent;
        
        // 强制触发响应式更新（重新赋值数组）
        this.aiMessages = [...this.aiMessages];

        // 滚动到底部（显示最新内容）
        setTimeout(() => {
          this.aiChatScroller.scrollEdge(Edge.Bottom);
        }, 50);
      },
      // onComplete: 完成回调
      (fullContent: string) => {
        console.info('[AI] ✅ 完成，总长度:', fullContent.length);
        this.isAILoading = false;

        // 确保显示完整内容（防止增量更新丢失）
        if (fullContent && this.aiMessages[aiMessageIndex].content !== fullContent) {
          this.aiMessages[aiMessageIndex].content = fullContent;
        }

        // 如果没有内容，设置错误提示
        if (!this.aiMessages[aiMessageIndex].content) {
          this.aiMessages[aiMessageIndex].content = '抱歉，AI暂时没有回复。';
        }

        // 🔥 强制触发响应式更新
        this.aiMessages = [...this.aiMessages];

        // 最后滚动
        setTimeout(() => {
          this.aiChatScroller.scrollEdge(Edge.Bottom);
        }, 100);
      },
      // onError: 错误回调
      (error: string) => {
        console.error('[AI] ❌ 错误:', error);
        this.isAILoading = false;
        this.aiMessages[aiMessageIndex].content = `错误: ${error}`;
        
        // 🔥 强制触发响应式更新
        this.aiMessages = [...this.aiMessages];
      }
    );

    // 滚动到底部
    setTimeout(() => {
      this.aiChatScroller.scrollEdge(Edge.Bottom);
    }, 100);
  }

  // AI消息组件
  @Builder
  AIMessageItem(msg: AIMessage, index: number) {
    Row() {
      if (msg.role === 'assistant') {
        Image($rawfile('deepseek-copy-copy-copy.png'))
          .width(36)
          .height(36)
          .borderRadius(18)
          .margin({ right: 12 })
      } else {
        Blank()
      }

      Text(msg.content)
        .fontSize(15)
        .fontColor(msg.role === 'user' ? '#FFFFFF' : '#333333')
        .padding({
          left: 16,
          right: 16,
          top: 12,
          bottom: 12
        })
        .backgroundColor(msg.role === 'user' ? '#667eea' : '#F0F0F0')
        .borderRadius(18)
        .constraintSize({ maxWidth: '75%' })

      if (msg.role === 'user') {
        Image($rawfile('B站狗头.png'))
          .width(36)
          .height(36)
          .borderRadius(18)
          .margin({ left: 12 })
      } else {
        Blank()
      }
    }
    .width('100%')
    .alignItems(VerticalAlign.Top)
    .margin({ top: 0, bottom: 12 })
  }

  // 获取天气描述
  getWeatherDescription(): string {
    if (this.temperature === 0 && this.soilHumidity === 0) {
      return '等待数据...';
    }

    if (this.temperature > 30) {
      return '炎热天气';
    } else if (this.temperature > 25) {
      return '温暖天气';
    } else if (this.temperature > 18) {
      return '舒适天气';
    } else if (this.temperature > 10) {
      return '凉爽天气';
    } else {
      return '寒冷天气';
    }
  }

  // 获取天气图标
  getWeatherIcon(): string {
    if (this.temperature === 0 && this.soilHumidity === 0) {
      return '⏳';
    }

    // 根据光照强度判断天气
    if (this.lightIntensity > 800) {
      return '☀️'; // 晴天
    } else if (this.lightIntensity > 500) {
      return '🌤️'; // 多云
    } else if (this.lightIntensity > 200) {
      return '☁️'; // 阴天
    } else {
      return '🌧️'; // 雨天/夜晚
    }
  }
}