  /**
   * 根据用户模式获取对应的菜单项列表
   *
   * 该方法根据当前用户的登录状态和模式，动态返回不同的菜单项
   * 实现了基于用户权限的菜单显示控制
   *
   * @returns ProfileMenuItem[] 返回当前用户模式下可用的菜单项数组
   *
   * 用户模式说明：
   * - 'guest': 游客模式，只显示帮助和关于菜单
   * - 'logged_in': 已登录用户，显示所有功能菜单
   * - 其他状态: 未登录状态，不显示任何菜单
   *
   * 使用场景：
   * - 在ForEach循环中动态渲染菜单列表
   * - 根据用户权限控制功能访问
   */
  getMenuItemsForCurrentMode(): ProfileMenuItem[] {
    if (this.userMode === 'guest') {
      // 游客模式只显示帮助和关于
      return this.menuItems.filter(item =>
      item.id === 'help' || item.id === 'about'
      );
    } else if (this.userMode === 'logged_in') {
      // 已登录用户显示所有菜单
      return this.menuItems;
    } else {
      // 未登录状态不显示菜单
      return [];
    }
  }

