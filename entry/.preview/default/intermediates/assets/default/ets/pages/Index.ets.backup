                  .margin({ bottom: 6 })
                Text(this.controlDevices.length > 0 ?
                  `${Math.round((this.onlineDeviceCount / this.controlDevices.length) * 100)}%` :
                  '0%')
                  .fontSize(20)
                  .fontWeight(FontWeight.Bold)
                  .fontColor('#2196F3')
                  .margin({ bottom: 2 })
                Text('在线率')
                  .fontSize(11)
                  .fontColor('#666666')
              }
              .layoutWeight(1)
              .alignItems(HorizontalAlign.Center)
            }
            .width('100%')
          }
          .width('100%')
          .padding(16)
          .backgroundColor('#FFFFFF')
          .borderRadius(12)
          .margin({
            left: 12,
            right: 12,
            top: 0,
            bottom: 8
          })

          // 系统状态提示
          Column() {
            Row() {
              Text(this.getMqttStatusIcon())
                .fontSize(16)
                .margin({ right: 6 })
              Text('控制系统')
                .fontSize(14)
                .fontColor('#666666')
                .layoutWeight(1)
              Text(this.mqttStatusText)
                .fontSize(14)
                .fontWeight(FontWeight.Bold)
                .fontColor(this.getMqttStatusColor())
            }
            .width('100%')
            .padding(12)
            .backgroundColor('#FFFFFF')
            .borderRadius(8)
          }
          .width('100%')
          .padding({ left: 12, right: 12, bottom: 12 })
        }
        .width('100%')
      }
      .flexGrow(1)
      .flexShrink(1)
      .backgroundColor('#F1F1F1')
      .width('100%')
      .height('100%')
      .scrollBar(BarState.Off)
      .edgeEffect(EdgeEffect.Spring)
      .scrollable(ScrollDirection.Vertical)
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#F1F1F1')
  }

  // 控制页面内容（全新设计）
  @Builder
  ControlPageContent() {
    Column() {
      // 顶部连接状态卡片
      Column() {
        Row() {
          // 连接状态指示器
          Row() {
            Text(this.getMqttStatusIcon())
              .fontSize(20)
              .margin({ right: 8 })

            Column() {
              Text('设备控制中心')
                .fontSize(14)
                .fontColor('#666666')
              Text(this.mqttStatusText)
                .fontSize(16)
                .fontWeight(FontWeight.Medium)
                .fontColor(this.getMqttStatusColor())
                .margin({ top: 2 })
            }
            .alignItems(HorizontalAlign.Start)
          }
          .layoutWeight(1)
        }
        .width('100%')
        .padding(16)

        // UID显示（如果已配置）
        if (this.bemfaUID) {
          Row() {
            Text('UID:')
              .fontSize(12)
              .fontColor('#999999')
            Text(this.getMaskedUID())
              .fontSize(12)
              .fontColor('#666666')
              .margin({ left: 4 })
          }
          .width('100%')
          .padding({ left: 16, right: 16, bottom: 12 })
        }
      }
      .width('92%')
      .backgroundColor('#FFFFFF')
      .borderRadius(12)
      .margin({ top: 16, bottom: 16 })

      // 设备统计卡片
      Row() {
        Column() {
          Text('在线设备')
            .fontSize(14)
            .fontColor('#666666')
            .margin({ bottom: 4 })
          Text(`${this.onlineDeviceCount}`)
            .fontSize(24)
            .fontWeight(FontWeight.Bold)
            .fontColor('#4CAF50')
        }
        .alignItems(HorizontalAlign.Center)
        .layoutWeight(1)

        Column() {
          Text('运行设备')
            .fontSize(14)
            .fontColor('#666666')
            .margin({ bottom: 4 })
          Text(`${this.activeDeviceCount}`)
            .fontSize(24)
            .fontWeight(FontWeight.Bold)
            .fontColor('#007DFF')
        }
        .alignItems(HorizontalAlign.Center)
        .layoutWeight(1)

        Column() {
          Text('总设备')
            .fontSize(14)
            .fontColor('#666666')
            .margin({ bottom: 4 })
          Text(`${this.controlDevices.length}`)
            .fontSize(24)
            .fontWeight(FontWeight.Bold)
            .fontColor('#666666')
        }
        .alignItems(HorizontalAlign.Center)
        .layoutWeight(1)
      }
      .width('92%')
      .backgroundColor('#FFFFFF')
      .borderRadius(12)
      .padding(16)
      .margin({ bottom: 16 })

      // 快速场景控制
      Row() {
        Button({ type: ButtonType.Normal }) {
          Row() {
            Image($rawfile('开启.png'))
              .width(18)
              .height(18)
              .fillColor('#FFFFFF')
              .margin({ right: 6 })
            Text('全部开启')
              .fontSize(15)
              .fontColor('#FFFFFF')
          }
        }
        .backgroundColor('#00B75E')
        .borderRadius(10)
        .layoutWeight(1)
        .height(42)
        .enabled(this.mqttStatus === MqttStatus.CONNECTED)
        .onClick(() => {
          this.toggleAllDevicesMQTT(true);
        })

        Button({ type: ButtonType.Normal }) {
          Row() {
            Image($rawfile('关闭.png'))
              .width(18)
              .height(18)
              .fillColor('#FFFFFF')
              .margin({ right: 6 })
            Text('全部关闭')
              .fontSize(15)
              .fontColor('#FFFFFF')
          }
        }
        .backgroundColor('#E34607')
        .borderRadius(10)
        .layoutWeight(1)
        .height(42)
        .margin({ left: 10 })
        .enabled(this.mqttStatus === MqttStatus.CONNECTED)
        .onClick(() => {
          this.toggleAllDevicesMQTT(false);
        })
      }
      .width('92%')
      .margin({ bottom: 10 })

      // 刷新按钮（单独一行）
      Button({ type: ButtonType.Normal }) {
        Row() {
          Image($rawfile('刷新.png'))
            .width(16)
            .height(16)
            .fillColor('#6531FF')
            .margin({ right: 6 })
          Text('刷新设备状态')
            .fontSize(13)
            .fontColor('#6531FF')
        }
      }
      .backgroundColor('#F5F2FF')
      .borderRadius(10)
      .width('92%')
      .height(38)
      .margin({ bottom: 12 })
      .onClick(() => {
        this.refreshDeviceOnlineStatus();
      })

      // 设备控制列表
      if (this.controlDevices.length > 0) {
        List() {
          ForEach(this.controlDevices, (device: ControlDevice) => {
            ListItem() {
              this.ControlDeviceCard(device)
            }
            .margin({ bottom: 12 })
          })
        }
        .width('92%')
        .height('100%')
        .layoutWeight(1)
      } else {
        // 空状态提示
        Column() {
          Text('📱')
            .fontSize(64)
            .margin({ bottom: 16 })

          Text('暂无设备')
            .fontSize(18)
            .fontColor('#666666')
            .margin({ bottom: 8 })

          Text('系统正在从巴法云同步设备...')
            .fontSize(14)
            .fontColor('#999999')
            .margin({ bottom: 24 })

          Button('手动同步')
            .fontSize(16)
            .fontColor('#FFFFFF')
            .backgroundColor('#007DFF')
            .borderRadius(8)
            .height(44)
            .padding({ left: 32, right: 32 })
            .onClick(() => {
              this.syncDevicesFromBemfa();
            })
        }
        .width('92%')
        .height('100%')
        .layoutWeight(1)
        .justifyContent(FlexAlign.Center)
      }
    }
    .width('100%')
    .height('100%')
    .padding(0)
    .margin(0)
    .justifyContent(FlexAlign.Start)
    .backgroundColor('#F1F1F1')
  }

  // 控制设备卡片（全新设计）
  @Builder
  ControlDeviceCard(device: ControlDevice) {
    Column() {
      Row() {
        // 设备图标和信息
        Row() {
          Image(device.isActive ? $rawfile('开启.png') : $rawfile('关闭.png'))
            .width(32)
            .height(32)
            .fillColor(device.isActive ? '#00B75E' : '#8A8F99')
            .margin({ right: 12 })

          Column() {
            // 设备名称（带编辑按钮）
            Row() {
              Text(device.name)
                .fontSize(18)
                .fontWeight(FontWeight.Bold)
                .fontColor('#333333')

              // 编辑昵称按钮
              Text('✏️')
                .fontSize(14)
                .margin({ left: 8 })
                .onClick(() => {
                  this.editingDevice = device;
                  this.newDeviceName = device.name;
                  this.showEditNameDialog = true;
                })
            }
            .margin({ bottom: 4 })

            // 设备区域
            Text(device.area)
              .fontSize(14)
              .fontColor('#666666')
              .margin({ bottom: 4 })

            // 主题名称
            Text(`主题: ${device.topic}`)
              .fontSize(12)
              .fontColor('#999999')
          }
          .alignItems(HorizontalAlign.Start)
        }
        .layoutWeight(1)

        // 开关控制
        Toggle({ type: ToggleType.Switch, isOn: device.isActive })
          .selectedColor('#00B75E')
          .switchPointColor('#FFFFFF')
          .enabled(this.mqttStatus === MqttStatus.CONNECTED && device.isOnline)
          .onChange((isOn: boolean) => {
            this.toggleDeviceMQTT(device.id, isOn);
          })
      }
      .width('100%')
      .margin({ bottom: 12 })

      // 设备状态信息
      Row() {
        // 运行状态
        Row() {
          Text('状态:')
            .fontSize(13)
            .fontColor('#8A8F99')

          Text(device.isActive ? '运行中' : '已停止')
            .fontSize(13)
            .fontWeight(FontWeight.Medium)
            .fontColor(device.isActive ? '#00B75E' : '#8A8F99')
            .margin({ left: 4 })
        }

        Blank()

        // 在线状态标签
        Row() {
          Text(device.isOnline ? '●' : '●')
            .fontSize(11)
            .fontColor(device.isOnline ? '#00B75E' : '#CCCCCC')
          Text(device.isOnline ? '在线' : '离线')
            .fontSize(12)
            .fontColor(device.isOnline ? '#00B75E' : '#8A8F99')
            .margin({ left: 3 })
        }
        .padding({
          left: 10,
          right: 10,
          top: 4,
          bottom: 4
        })
        .backgroundColor(device.isOnline ? '#F0FDF5' : '#F1F1F1')
        .borderRadius(12)
      }
      .width('100%')
    }
    .width('100%')
    .padding(14)
    .backgroundColor('#FFFFFF')
    .borderRadius(12)
    .shadow({ radius: 2, color: '#08000000', offsetY: 1 })
  }

  // 通过MQTT切换单个设备
  toggleDeviceMQTT(deviceId: number, isActive: boolean) {
    const device = this.controlDevices.find(d => d.id === deviceId);
    if (!device) {
      return;
    }

    const command = isActive ? 'on' : 'off';
    const topic = `${device.topic}/set`; // 使用/set后缀发送控制命令

    console.info(`[控制] 发送命令到 ${topic}: ${command}`);

    mqttService.publish(topic, command, 1, false).then((success) => {
      if (success) {
        console.info(`[控制] 命令发送成功`);
        // 更新本地状态（实际状态应该由设备反馈确认）
        const deviceIndex = this.controlDevices.findIndex(d => d.id === deviceId);
        if (deviceIndex !== -1) {
          this.controlDevices[deviceIndex].isActive = isActive;
          this.updateDeviceStatistics();
        }
      } else {
        console.error(`[控制] 命令发送失败`);
      }
    });
  }

  // 通过MQTT切换所有设备
  toggleAllDevicesMQTT(isActive: boolean) {
    const command = isActive ? 'on' : 'off';

    this.controlDevices.forEach(device => {
      const topic = `${device.topic}/set`;
      mqttService.publish(topic, command, 1, false);

      // 更新本地状态
      const deviceIndex = this.controlDevices.findIndex(d => d.id === device.id);
      if (deviceIndex !== -1) {
        this.controlDevices[deviceIndex].isActive = isActive;
      }
    });

    this.updateDeviceStatistics();
  }

  // 更新设备统计
  updateDeviceStatistics() {
    this.activeDeviceCount = this.controlDevices.filter(d => d.isActive).length;
    this.onlineDeviceCount = this.controlDevices.filter(d => d.isOnline).length;
  }

  // 确认修改设备昵称
  async confirmEditDeviceName() {
    if (!this.editingDevice) {
      console.error('[控制] 没有选中要编辑的设备');
      return;
    }

    if (!this.newDeviceName || this.newDeviceName.trim().length === 0) {
      console.error('[控制] 昵称不能为空');
      return;
    }

    const device = this.editingDevice;
    const newName = this.newDeviceName.trim();

    // 如果昵称没有改变，直接关闭对话框
    if (newName === device.name) {
      this.showEditNameDialog = false;
      return;
    }

    console.info(`[控制] 修改设备昵称: ${device.topic} (${device.name} → ${newName})`);

    try {
      // 调用API修改昵称
      const result = await bemfaCloudService.modifyTopicName(
        device.topic,
        newName,
        BemfaConfig.PROTOCOL_TYPE_MQTT_V1
      );

      if (result.code === 0) {
        console.info('[控制] ✅ 修改昵称成功');

        // 更新本地设备列表
        const deviceIndex = this.controlDevices.findIndex(d => d.id === device.id);
        if (deviceIndex !== -1) {
          this.controlDevices[deviceIndex].name = newName;
        }

        // 关闭对话框
        this.showEditNameDialog = false;

        // 提示成功（可选：使用Toast组件）
        console.info(`[控制] 设备 ${device.topic} 昵称已更新为: ${newName}`);
      } else {
        console.error('[控制] ❌ 修改昵称失败:', result.message);
        // 这里可以添加错误提示UI
      }
    } catch (error) {
      console.error('[控制] 修改昵称异常:', JSON.stringify(error));
    }
  }

  // 获取MQTT状态图标
  getMqttStatusIcon(): string {
    switch (this.mqttStatus) {
      case MqttStatus.CONNECTED:
        return '🟢';
      case MqttStatus.CONNECTING:
      case MqttStatus.RECONNECTING:
        return '🟡';
      case MqttStatus.ERROR:
        return '🔴';
      default:
        return '⚪';
    }
  }

  // 获取MQTT状态颜色
  getMqttStatusColor(): string {
    switch (this.mqttStatus) {
      case MqttStatus.CONNECTED:
        return '#4CAF50';
      case MqttStatus.CONNECTING:
      case MqttStatus.RECONNECTING:
        return '#FF9800';
      case MqttStatus.ERROR:
        return '#F44336';
      default:
        return '#999999';
    }
  }

  // 获取传感器设备数量
  getSensorDeviceCount(): number {
    // 支持两种识别方式：主题名后缀004 或 设备类型为传感器
    return this.controlDevices.filter((device: ControlDevice) =>
    device.topic.endsWith('004') || device.deviceType === '传感器'
    ).length;
  }

  // 根据温度获取天气描述
  getWeatherDesc(): string {
    if (this.temperature === 0) {
      return '等待数据';
    } else if (this.temperature < 10) {
      return '寒冷';
    } else if (this.temperature < 20) {
      return '凉爽';
    } else if (this.temperature < 28) {
      return '舒适';
    } else if (this.temperature < 35) {
      return '温暖';
    } else {
      return '炎热';
    }
  }

  // 获取脱敏的UID
  getMaskedUID(): string {
    if (!this.bemfaUID || this.bemfaUID.length < 8) {
      return '未配置';
    }
    return this.bemfaUID.substring(0, 4) + '***' + this.bemfaUID.substring(this.bemfaUID.length - 4);
  }

  // 初始化MQTT连接
  async initMQTT() {
    if (!this.bemfaUID) {
      console.warn('[MQTT] UID未配置');
      return;
    }

    // 设置客户端ID
    mqttService.setClientId(this.bemfaUID);

    // 设置状态回调
    mqttService.onStatusChange((status: MqttStatus) => {
      this.mqttStatus = status;

      switch (status) {
        case MqttStatus.DISCONNECTED:
          this.mqttStatusText = '未连接';
          break;
        case MqttStatus.CONNECTING:
          this.mqttStatusText = '连接中...';
          break;
        case MqttStatus.CONNECTED:
          this.mqttStatusText = '已连接';
          // 连接成功后订阅所有设备主题
          this.subscribeAllDevices();
          break;
        case MqttStatus.RECONNECTING:
          this.mqttStatusText = '重连中...';
          break;
        case MqttStatus.ERROR:
          this.mqttStatusText = '连接失败';
          break;
      }
    });

    // 设置消息回调
    mqttService.onMessage((message: MqttMessage) => {
      console.info('[MQTT] 收到消息:', message.topic, message.payload);
      this.handleMQTTMessage(message);
    });

    // 连接MQTT服务器
    await mqttService.connect();
  }

  // 订阅所有设备主题
  subscribeAllDevices() {
    this.controlDevices.forEach(device => {
      mqttService.subscribe(device.topic);
      console.info('[MQTT] 订阅主题:', device.topic);
    });

    // 订阅完成后，查询所有设备的在线状态
    this.refreshDeviceOnlineStatus();
  }

  // 刷新所有设备的在线状态（优化版：使用getAllTopics一次获取所有状态）
  async refreshDeviceOnlineStatus() {
    console.info('[控制] 开始查询设备在线状态');

    try {
      // 方式1：使用getAllTopics API（推荐，更高效，一次请求获取所有状态）
      const result = await bemfaCloudService.getAllTopics(1);

      if (result.code === 0 && result.data?.data && result.data.data.length > 0) {
        // 创建在线状态映射表
        const onlineMap = new Map<string, boolean>();
        result.data.data.forEach(topic => {
          onlineMap.set(topic.topic, topic.online);
        });

        // 更新设备在线状态
        let onlineCount = 0;
        this.controlDevices.forEach((device, index) => {
          const isOnline = onlineMap.get(device.topic) || false;
          this.controlDevices[index].isOnline = isOnline;
          if (isOnline) {
            onlineCount++;
          }
          console.info(`[控制] 设备 ${device.name} (${device.topic}): ${isOnline ? '🟢在线' : '⚪离线'}`);
        });

        console.info(`[控制] ✅ 在线状态更新完成，在线设备: ${onlineCount}/${this.controlDevices.length}`);
      }

      this.updateDeviceStatistics();
    } catch (error) {
      console.error('[控制] ❌ 刷新在线状态失败:', error);
    }
  }

  // 单独查询某个设备的在线状态（备用方法，用于精确查询单个设备）
  async checkSingleDeviceOnline(topic: string) {
    console.info('[控制] 精确查询设备在线状态:', topic);

    const result = await bemfaCloudService.checkDeviceOnline(topic, 1);

    if (result.code === 0) {
      console.info(`[控制] 设备 ${topic}: ${result.data ? '🟢在线' : '⚪离线'}`);
      return result.data;
    } else {
      console.warn(`[控制] 查询失败: ${result.message}`);
      return false;
    }
  }

  // 刷新传感器数据（从巴法云API获取最新消息，仅MQTT协议）
  async refreshSensorData() {
    console.info('[首页] 开始刷新传感器数据（MQTT协议）');

    try {
      // 查询MQTT协议的传感器设备
      const result = await bemfaCloudService.getAllTopics(1);

      // 注意：API返回的是 data.data 的嵌套结构
      if (result.code === 0 && result.data?.data && result.data.data.length > 0) {
        // 过滤出传感器设备（后缀004 或 设备类型为sensor）
        const sensorDevices = result.data.data.filter((topic: TopicDetail) =>
        topic.topic.endsWith('004') || topic.deviceType === 'sensor'
        );

        if (sensorDevices.length > 0) {
          // 使用第一个传感器设备的数据
          const sensor = sensorDevices[0];
          if (sensor.msg) {
            console.info(`[首页] 传感器数据更新: ${sensor.name} -> ${sensor.msg}`);
            this.parseSensorData(sensor.msg);
          } else {
            console.info('[首页] 传感器设备未发送数据');
          }
        } else {
          console.info('[首页] 未找到传感器设备（后缀004）');
        }
      } else {
        console.info('[首页] 获取设备列表失败或为空');
      }
    } catch (error) {
      console.error('[首页] 刷新传感器数据失败:', error);
    }
  }

  // 从巴法云同步设备列表（仅MQTT协议）
  async syncDevicesFromBemfa() {
    console.info('[控制] 开始从巴法云同步设备列表（MQTT协议）');
    console.info('[控制] 当前UID:', this.bemfaUID.substring(0, 8) + '...');

    // 获取MQTT协议设备（type=1）
    const result = await bemfaCloudService.getAllTopics(1);

    console.info('[控制] API返回状态码:', result.code);
    console.info('[控制] API返回消息:', result.msg);
    console.info('[控制] API返回数据数量:', result.data?.data?.length || 0);

    // 注意：API返回的是 data.data 的嵌套结构
    if (result.code === 0 && result.data?.data && result.data.data.length > 0) {
      const devices = result.data.data;
      console.info(`[控制] ✅ 找到 ${devices.length} 个MQTT设备`);

      // 打印所有设备信息
      devices.forEach((topic, idx) => {
        console.info(`[控制] 设备${idx + 1}: ${topic.topic} | 名称: ${topic.name} | 在线: ${topic.online}`);
      });

      // 转换设备列表
      const newDevices: ControlDevice[] = devices.map((topic: TopicDetail, index: number): ControlDevice => {
        const device: ControlDevice = {
          id: index + 1,
          name: topic.name || topic.topic,
          topic: topic.topic,
          isActive: topic.msg === 'on' || topic.msg === '1',
          isOnline: topic.online,
          area: topic.room || '未分组',
          deviceType: this.getDeviceTypeName(topic.deviceType)
        };

        // 如果是传感器设备（后缀004 或 设备类型为sensor），立即解析最后的消息更新首页数据
        if ((topic.topic.endsWith('004') || topic.deviceType === 'sensor') && topic.msg) {
          console.info(`[控制] 发现传感器设备: ${topic.name}, 最后消息: ${topic.msg}`);
          this.parseSensorData(topic.msg);
        }

        return device;
      });

      this.controlDevices = newDevices;
      this.updateDeviceStatistics();

      console.info(`[控制] ✅ 同步成功，共 ${newDevices.length} 个MQTT设备`);

      // 同步后重新订阅所有主题
      if (this.mqttStatus === MqttStatus.CONNECTED) {
        this.subscribeAllDevices();
      }
    } else {
      console.warn('[控制] ⚠️ 没有找到MQTT协议设备');
      console.warn('[控制] 返回码:', result.code);
      console.warn('[控制] 错误信息:', result.msg);
      console.warn('[控制] 数据为空:', result.data?.data ? '否' : '是');
      this.controlDevices = [];
    }
  }

  // 获取设备类型中文名称
  getDeviceTypeName(deviceType?: string): string {
    const typeMap: Record<string, string> = {
      'outlet': '插座',
      'light': '灯泡',
      'fan': '风扇',
      'sensor': '传感器',
      'aircondition': '空调',
      'switch': '开关',
      'curtain': '窗帘',
      'thermostat': '温控器',
      'waterheater': '热水器',
      'television': '电视',
      'airpurifier': '空气净化器'
    };

    return typeMap[deviceType || ''] || '开关';
  }

  // 获取设备历史消息
  async loadDeviceHistory(topic: string, num: number = 20) {
    this.isLoadingHistory = true;
    this.selectedDeviceForHistory = topic;
    console.info(`[分析] 加载设备 ${topic} 的历史消息，数量: ${num}`);

    const result = await bemfaCloudService.getMessages(topic, 1, num);

    if (result.code === 0 && result.data && result.data.length > 0) {
      this.historyMessages = result.data;
      console.info(`[分析] ✅ 成功加载 ${result.data.length} 条历史消息`);
    } else {
      this.historyMessages = [];
      console.warn('[分析] ⚠️ 未获取到历史消息');
      console.warn('[分析] 返回码:', result.code);
      console.warn('[分析] 错误信息:', result.message);
    }

    this.isLoadingHistory = false;
  }

  // 处理MQTT消息
  handleMQTTMessage(message: MqttMessage) {
    // 查找对应的设备
    const device = this.controlDevices.find(d => d.topic === message.topic);
    if (!device) {
      return;
    }

    const deviceIndex = this.controlDevices.findIndex(d => d.topic === message.topic);
    if (deviceIndex === -1) {
      return;
    }

    // 解析消息内容
    const payload = message.payload.toLowerCase();

    // 如果是传感器设备（后缀004 或 设备类型为传感器），解析传感器数据
    if (message.topic.endsWith('004') || device.deviceType === '传感器') {
      this.parseSensorData(message.payload);
    }

    // 更新设备状态
    if (payload === 'on' || payload === '1') {
      this.controlDevices[deviceIndex].isActive = true;
    } else if (payload === 'off' || payload === '0') {
      this.controlDevices[deviceIndex].isActive = false;
    }

    // 标记设备为在线（收到消息说明设备在线）
    this.controlDevices[deviceIndex].isOnline = true;

    this.updateDeviceStatistics();
  }

  // 解析传感器数据（格式：temp:25,humi:68,light:850）
  parseSensorData(payload: string) {
    let temperature: number | undefined = undefined;
    let humidity: number | undefined = undefined;
    let lightIntensity: number | undefined = undefined;

    try {
      // 尝试解析JSON格式
      const data: Record<string, number> = JSON.parse(payload) as Record<string, number>;
      if (data.temperature !== undefined) {
        this.temperature = Math.round(data.temperature);
        temperature = data.temperature;
      }
      if (data.humidity !== undefined) {
        this.soilHumidity = Math.round(data.humidity);
        humidity = data.humidity;
      }
      if (data.light !== undefined) {
        this.lightIntensity = Math.round(data.light);
        lightIntensity = data.light;
      }
      console.info('[传感器] JSON格式数据更新:', JSON.stringify(data));
    } catch (e) {
      // 尝试解析键值对格式 (temp:25,humi:68,light:850)
      const pairs = payload.split(',');
      pairs.forEach(pair => {
        const parts = pair.split(':');
        if (parts.length === 2) {
          const key = parts[0];
          const value = parts[1];
          const numValue = parseFloat(value);
          if (!isNaN(numValue)) {
            if (key === 'temp' || key === 'temperature') {
              this.temperature = Math.round(numValue);
              temperature = numValue;
              console.info('[传感器] 温度更新:', this.temperature);
            } else if (key === 'humi' || key === 'humidity' || key === 'soil') {
              this.soilHumidity = Math.round(numValue);
              humidity = numValue;
              console.info('[传感器] 湿度更新:', this.soilHumidity);
            } else if (key === 'light' || key === 'lux') {
              this.lightIntensity = Math.round(numValue);
              lightIntensity = numValue;
              console.info('[传感器] 光照更新:', this.lightIntensity);
            }
          }
        }
      });
    }

    // 数据更新后，自动记录到分析页面
    this.updateAnalysisData();

    // 🔥 自动上传传感器数据到服务器
    this.uploadSensorDataToServer(temperature, humidity, lightIntensity);
  }

  /**
   * 上传传感器数据到服务器
   */
  private async uploadSensorDataToServer(
    temperature?: number,
    humidity?: number,
    lightIntensity?: number
  ): Promise<void> {
    // 检查是否有有效数据
    if (temperature === undefined && humidity === undefined && lightIntensity === undefined) {
      console.warn('[传感器上传] 没有有效数据，跳过上传');
      return;
    }

    try {
      // 构建上传数据
      const uploadData: SensorDataUploadRequest = {
        device_topic: 'farm001', // 默认设备主题，可以根据实际情况动态获取
        temperature: temperature,
        humidity: humidity,
        light_intensity: lightIntensity
      };

      // 如果用户已登录，添加用户ID
      if (this.userProfile.id > 0) {
        uploadData.user_id = this.userProfile.id;
      }

      console.info('[传感器上传] 准备上传数据:', JSON.stringify(uploadData));

      // 调用API上传
      const response = await apiService.uploadSensorData(uploadData);

      if (response.success) {
        console.info('[传感器上传] ✅ 上传成功:', response.message);
      } else {
        console.error('[传感器上传] ❌ 上传失败:', response.message);
      }
    } catch (error) {
      console.error('[传感器上传] ❌ 上传异常:', error);
    }
  }

  // 底部标签构建器 - 现代渐变配色
  @Builder
  TabBuilder(title: string, index: number) {
    Column() {
      // 图标 - 激活状态
      if (this.currentIndex === index) {
        Image(index === 0 ? $rawfile('首页.png') :
          index === 1 ? $rawfile('控制.png') :
            index === 2 ? $rawfile('分析.png') :
              $rawfile('我的.png'))
          .width(28)
          .height(28)
          .fillColor('#4facfe')
          .transition({ type: TransitionType.All, scale: { x: 0.9, y: 0.9 }, opacity: 0 })
          .animation({
            duration: 200,
            curve: Curve.EaseOut
          })
      } else {
        // 未激活状态
        Image(index === 0 ? $rawfile('首页.png') :
          index === 1 ? $rawfile('控制.png') :
            index === 2 ? $rawfile('分析.png') :
              $rawfile('我的.png'))
          .width(24)
          .height(24)
          .fillColor('#999999')
          .opacity(0.6)
      }

      // 标题文字
      Text(title)
        .fontSize(this.currentIndex === index ? 12 : 11)
        .fontColor(this.currentIndex === index ? '#4facfe' : '#999999')
        .fontWeight(this.currentIndex === index ? FontWeight.Bold : FontWeight.Normal)
        .margin({ top: 4 })
        .transition({ type: TransitionType.All, opacity: 0.5 })
        .animation({
          duration: 200,
          curve: Curve.EaseOut
        })
    }
    .width('100%')
    .padding({ top: 8, bottom: 8 })
    .justifyContent(FlexAlign.Center)
  }

